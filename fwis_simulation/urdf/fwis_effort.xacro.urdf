  <link name="lidar_link">
    <inertial>
      <origin xyz="-0.000935578802131328 0.000161725012697918 -0.0114789211216018" rpy="0 0 0" />
      <mass value="0.0853398661286776" />
      <inertia
        ixx="0.0001"
        ixy="0"
        ixz="0"
        iyy="0.0001"
        iyz="0"
        izz="0.0001" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file://$(find fwis_simulation)/models/mobile_assembly/meshes/lidar_link.STL"
          scale="1 1 1" />
      </geometry>
      <material name="">
        <color rgba="0.627450980392157 0.627450980392157 0.627450980392157 1" />
      </material>
