  <joint name="lidar_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="lidar_link" />
  </joint>

  <!-- =============== Sensors =============== -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>true</visualize>
      <topic>imu</topic>
      <gz_frame_id>imu_link</gz_frame_id>
    </sensor>
  </gazebo>

  <gazebo reference="lidar_link">
    <sensor name="lidar_sensor" type="gpu_lidar">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <topic>scan</topic>
      <gz_frame_id>lidar_link</gz_frame_id>

      <ray>
        <scan>
          <horizontal>
            <samples>640</samples>
            <resolution>1.0</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.4</min>
          <max>12.0</max>
          <resolution>0.015</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
    </sensor>
  </gazebo>

  <!-- =============== Cameras =============== -->
  <link name="arucam_left_link">
    <inertial>
      <origin xyz="0.00 0.38 0.30" rpy="0 0 0" />
      <mass value="0.05" />
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5" />
    </inertial>
  </link>
  <joint name="arucam_left_joint" type="fixed">
    <origin xyz="0.00 0.25 0.30" rpy="0 0 1.570796" />
    <parent link="base_link" />
    <child link="arucam_left_link" />
  </joint>
  <gazebo reference="arucam_left_link">
    <sensor name="arucam_left" type="camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <topic>arucam_left/image</topic>
      <gz_frame_id>arucam_left_link</gz_frame_id>
      <camera>
        <horizontal_fov>1.047</horizontal_fov> <!-- 60deg -->
        <image>
          <width>1920</width>
          <height>1080</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>30.0</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>
  <link name="arucam_right_link">
    <inertial>
      <origin xyz="0 -0.38 0.30" rpy="0 0 0" />
      <mass value="0.05" />
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5" />
    </inertial>
  </link>
  <joint name="arucam_right_joint" type="fixed">
    <origin xyz="0.00 -0.25 0.30" rpy="0 0 -1.570796" />
    <parent link="base_link" />
    <child link="arucam_right_link" />
  </joint>
  <gazebo reference="arucam_right_link">
    <sensor name="arucam_right" type="camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <topic>arucam_right/image</topic>
      <gz_frame_id>arucam_right_link</gz_frame_id>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>1920</width>
          <height>1080</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>30.0</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>

  <!-- =============== controller =============== -->
  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="drive1_axis_joint">
      <command_interface name="effort">
        <param name="min">-2.0</param>
        <param name="max">2.0</param>
      </command_interface>
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
    <joint name="drive2_axis_joint">
      <command_interface name="effort">
        <param name="min">-2.0</param>
        <param name="max">2.0</param>
      </command_interface>
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
    <joint name="drive3_axis_joint">
      <command_interface name="effort">
        <param name="min">-2.0</param>
        <param name="max">2.0</param>
      </command_interface>
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
    <joint name="drive4_axis_joint">
      <command_interface name="effort">
        <param name="min">-2.0</param>
        <param name="max">2.0</param>
      </command_interface>
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
    <joint name="motor1_axis_joint">
      <command_interface name="effort">
        <param name="min">-12.0</param>
        <param name="max">12.0</param>
      </command_interface>
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
    <joint name="motor2_axis_joint">
      <command_interface name="effort">
        <param name="min">-12.0</param>
        <param name="max">12.0</param>
      </command_interface>
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
    <joint name="motor3_axis_joint">
      <command_interface name="effort">
        <param name="min">-12.0</param>
        <param name="max">12.0</param>
      </command_interface>
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
    <joint name="motor4_axis_joint">
      <command_interface name="effort">
        <param name="min">-12.0</param>
        <param name="max">12.0</param>
      </command_interface>
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find fwis_simulation)/config/fwis_controller_effort.yaml</parameters>
    </plugin>
  </gazebo>
</robot>