      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file://$(find fwis_simulation)/models/mobile_assembly/meshes/motor4_move_link.STL"
