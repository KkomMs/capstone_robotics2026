          scale="1 1 1" />
      </geometry>
    </collision>
  </link>
  <joint name="imu_joint" type="fixed">
    <origin xyz="0 0 0.211175000000014" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="imu_link" />
    <axis xyz="0 0 0" />
  </joint>
  <link name="drive1_axis">
    <inertial>
      <origin xyz="7.20144609242523E-06 0.000342870324270744 -0.0212849883195843" rpy="0 0 0" />
      <mass value="0.454337488928621" />
      <inertia
        ixx="0.000650290774511231"
        ixy="1.73123745261005E-06"
        ixz="2.2699704007801E-08"
        iyy="0.000732680881388333"
