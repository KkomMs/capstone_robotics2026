          scale="1 1 1" />
      </geometry>
    </collision>
  </link>
  <joint name="motor1_axis_joint" type="continuous">
    <origin xyz="0 0 -0.1" rpy="0 0 0" />
    <parent link="drive1_axis" />
    <child link="motor1_axis" />
    <limit effort="12.0" velocity="58.64" />
    <axis xyz="0 1 0" />
  </joint>
  <link name="drive2_axis">
    <inertial>
      <origin xyz="-2.36907715667201E-12 0.000342945943395262 -0.0212849883196075" rpy="0 0 0" />
