  <!-- =============== Imu & Lidar =============== -->
  <link name="imu_link">
    <inertial>
      <origin xyz="5.26055032867845E-11 6.88395174197609E-11 0.206176522322599" rpy="0 0 0" />
      <mass value="0.0120002513274123" />
      <inertia
        ixx="0"
        ixy="0"
        ixz="0"
        iyy="0"
        iyz="0"
        izz="0" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file://$(find fwis_simulation)/models/mobile_assembly/meshes/imu_link.STL"
          scale="1 1 1" />
      </geometry>
      <material name="">
        <color rgba="0.964705882352941 0.964705882352941 0.952941176470588 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
