          scale="1 1 1" />
      </geometry>
    </collision>
  </link>
  <joint name="imu_joint" type="fixed">
    <origin xyz="0 0 -0.0357" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="imu_link" />
    <axis xyz="0 0 0" />
  </joint>
  <link name="lidar_link">
    <inertial>
      <origin xyz="-0.000943155147524105 0.000109183625657844 -0.0114789211211224" rpy="0 0 0" />
      <mass value="0.0853398661286776" />
      <inertia
        ixx="0.0001"
        ixy="0"
        ixz="0"
        iyy="0.0001"
        iyz="0"
        izz="0.0001" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file://$(find fwis_simulation)/models/mobile_assembly/meshes/lidar_link.STL"
          scale="1 1 1" />
      </geometry>
      <material name="">
        <color rgba="0.627450980392157 0.627450980392157 0.627450980392157 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file://$(find fwis_simulation)/models/mobile_assembly/meshes/lidar_link.STL"
          scale="1 1 1" />
      </geometry>
    </collision>
  </link>
  <joint name="lidar_joint" type="fixed">
    <origin xyz="0 0 -0.0357" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="lidar_link" />
  </joint>

  <!-- =============== Scanners =============== -->
  <link name="scanner1_link">
    <inertial>
      <origin xyz="-0.0266164289427567 0.0809928961412583 0.000176016302953885" rpy="0 0 0" />
      <mass value="0.380816890715382"/>
      <inertia
        ixx="0.0002"
        ixy="0"
        ixz="0"
        iyy="0.0004"
        iyz="0"
        izz="0.0005" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file://$(find fwis_simulation)/models/mobile_assembly/meshes/scanner1_link.STL"
          scale="1 1 1" />
      </geometry>
      <material name="">
        <color rgba="0.0980392156862745 0.0980392156862745 0.0980392156862745 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find fwis_simulation)/models/mobile_assembly/meshes/scanner1_link.STL"
          scale="1 1 1" />
      </geometry>
    </collision>
  </link>
  <joint name="scanner1_joint" type="continuous">
    <origin xyz="0.0271 0.0918 0.3976" rpy="0 0 0"/>
    <parent link="base_link" />
    <child link="scanner1_link" />
    <limit effort="2.5" lower="-3.14" upper="3.14" velocity="6.7" />
    <axis xyz="1 0 0" />
  </joint>
  <link name="scanner2_link">
    <inertial>
      <origin xyz="0.026616428443226 -0.0806280113590046 0.00768142023144541" rpy="0 0 0" />
      <mass value="0.380816890715382"/>
      <inertia
        ixx="0.0002"
        ixy="0"
        ixz="0"
        iyy="0.0004"
        iyz="0"
        izz="0.0005" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file://$(find fwis_simulation)/models/mobile_assembly/meshes/scanner2_link.STL"
          scale="1 1 1" />
      </geometry>
      <material name="">
        <color rgba="0.0980392156862745 0.0980392156862745 0.0980392156862745 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find fwis_simulation)/models/mobile_assembly/meshes/scanner2_link.STL"
          scale="1 1 1" />
      </geometry>
    </collision>
  </link>
  <joint name="scanner2_joint" type="continuous">
    <origin xyz="-0.0271 -0.0918 0.3976" rpy="0 0 0"/>
    <parent link="base_link" />
    <child link="scanner2_link" />
    <limit effort="2.5" lower="-3.14" upper="3.14" velocity="6.7" />
    <axis xyz="-1 0 0" />
  </joint>

  <!-- =============== Sensors =============== -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>true</visualize>
      <topic>imu</topic>
      <gz_frame_id>imu_link</gz_frame_id>
    </sensor>
  </gazebo>

  <gazebo reference="lidar_link">
    <sensor name="lidar_sensor" type="gpu_lidar">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <topic>scan</topic>
      <gz_frame_id>lidar_link</gz_frame_id>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1.0</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.4</min>
          <max>12.0</max>
          <resolution>0.015</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
    </sensor>
  </gazebo>

  <!-- 카메라 스펙 맞춰서 값 수정 필요 -->
  <gazebo reference="scanner1_link">
    <sensor name="scanner1" type="camera">
      <pose>0 0.15 0 0 0 1.57</pose>
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <topic>scanner1/image</topic>
      <gz_frame_id>scanner1_link</gz_frame_id>
      <camera>
        <horizontal_fov>1.047</horizontal_fov> <!-- 60deg -->
        <image>
          <width>1920</width>
          <height>1080</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>30.0</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>
  <gazebo reference="scanner2_link">
    <sensor name="scanner2" type="camera">
      <pose>0 -0.15 0 0 0 -1.57</pose>
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <topic>scanner2/image</topic>
      <gz_frame_id>scanner2_link</gz_frame_id>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>1920</width>
          <height>1080</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>30.0</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>

  <!-- =============== controller =============== -->
  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="drive1_axis_joint">
      <command_interface name="effort">
        <param name="min">-2.0</param>
        <param name="max">2.0</param>
      </command_interface>
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
    <joint name="drive2_axis_joint">
      <command_interface name="effort">
        <param name="min">-2.0</param>
        <param name="max">2.0</param>
      </command_interface>
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
    <joint name="drive3_axis_joint">
      <command_interface name="effort">
        <param name="min">-2.0</param>
        <param name="max">2.0</param>
      </command_interface>
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
    <joint name="drive4_axis_joint">
      <command_interface name="effort">
        <param name="min">-2.0</param>
        <param name="max">2.0</param>
      </command_interface>
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
    <joint name="motor1_axis_joint">
      <command_interface name="effort">
        <param name="min">-12.0</param>
        <param name="max">12.0</param>
      </command_interface>
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
    <joint name="motor2_axis_joint">
      <command_interface name="effort">
        <param name="min">-12.0</param>
        <param name="max">12.0</param>
      </command_interface>
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
    <joint name="motor3_axis_joint">
      <command_interface name="effort">
        <param name="min">-12.0</param>
        <param name="max">12.0</param>
      </command_interface>
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
    <joint name="motor4_axis_joint">
      <command_interface name="effort">
        <param name="min">-12.0</param>
        <param name="max">12.0</param>
      </command_interface>
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>

    <joint name="scanner1_joint">
      <command_interface name="position">
        <param name="min">-3.14</param>
        <param name="max">3.14</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">-0.7</param>
      </state_interface>
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
    <joint name="scanner2_joint">
      <command_interface name="position">
