<robot name="mobile_assembly">
  <link name="base_footprint">
  </link>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint" />
    <child link="base_link" />
    <origin xyz="0 0 0" rpy="0 0 0" />
  </joint>

  <link name="base_link">
    <inertial>
      <origin
        xyz="0.000154338729897341 0.000519187785971403 0.102508036106042" rpy="0 0 0" />
      <mass value="19.5136122526707" />
      <inertia
        ixx="0.08"
        ixy="0"
        ixz="0.00006"
        iyy="0.09"
        iyz="0"
        izz="0.16" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file://$(find fwis_simulation)/models/mobile_assembly/meshes/base_link.STL"
          scale="1 1 1" />
      </geometry>
      <material name="">
        <color rgba="0.627450980392157 0.627450980392157 0.627450980392157 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file://$(find fwis_simulation)/models/mobile_assembly/meshes/base_link.STL"
          scale="1 1 1" />
      </geometry>
    </collision>
  </link>
  <link name="drive1_axis">
    <inertial>
      <origin xyz="-1.74664221512799E-05 0.000342500867427764 -0.0212849883195494" rpy="0 0 0" />
      <mass value="0.454337488928621" />
      <inertia
        ixx="0.0007"
        ixy="0"
        ixz="0"
        iyy="0.0007"
        iyz="0"
        izz="0.001" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file://$(find fwis_simulation)/models/mobile_assembly/meshes/dir1_link.STL"
          scale="1 1 1" />
      </geometry>
      <material name="">
        <color rgba="0.8 0.8 0.8 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file://$(find fwis_simulation)/models/mobile_assembly/meshes/dir1_link.STL"
          scale="1 1 1" />
      </geometry>
    </collision>
  </link>
  <joint name="drive1_axis_joint" type="continuous">
    <origin xyz="0.215 0.215 0.09" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="drive1_axis" />
    <limit effort="2.0" lower="-3.14" upper="3.14" velocity="6.81" />
    <axis xyz="0 0 1" />
  </joint>
  <link name="motor1_axis">
    <inertial>
      <origin xyz="-5.55111512312578E-17 -5.55111512312578E-17 3.63207727782644E-18" rpy="0 0 0" />
      <mass value="0.661505484221104" />
      <inertia
        ixx="0.0007"
        ixy="0"
        ixz="0"
        iyy="0.001"
        iyz="0"
        izz="0.0007" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file://$(find fwis_simulation)/models/mobile_assembly/meshes/motor1_link.STL"
          scale="1 1 1" />
      </geometry>
      <material name="">
        <color rgba="0.0980392156862745 0.0980392156862745 0.0980392156862745 1" />
      </material>
    </visual>
    <collision>
